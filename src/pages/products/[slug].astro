---
import '../../styles/global.css'
import Layout from "../../layouts/Layout.astro";
import { ProductCatalog } from "../../logic/ProductCatalog";
import productsData from "../../data/products.json";
import type { Product } from "../../logic/Product"; 

// 1. getStaticPaths() tells Astro which pages to build
export function getStaticPaths() {

  const catalog = new ProductCatalog(productsData);
  const products = catalog.getAllProducts();

  return products.map((product) => ({
      params: { slug: product.slug }, 
      props: { product }, 
    }))
}

// // 2. Explicitly type the Props for this component
interface Props {
  product: Product;
}

const { product } = Astro.props;
---



<Layout title={`${product.title} | Jewelry Store`}>
  <div class="container mx-auto px-4 py-12">
    <!-- Back Button -->
    <a href="/" class="text-gray-500 hover:text-black mb-8 inline-block transition-colors">
      &larr; Back to Collection
    </a>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <!-- Image Column -->
      <div class="bg-gray-50 rounded-lg p-8 flex justify-center shadow-inner">
        <img 
          src={product.image} 
          alt={product.title} 
          class="w-full max-w-md rounded shadow-lg object-cover" 
        />
      </div>
      
      <!-- Details Column -->
      <div>
        <span class="uppercase text-sm tracking-widest text-gray-400 font-semibold">
          {product.category}
        </span>
        <h1 class="text-4xl font-bold mt-2 mb-4">{product.title}</h1>
        
        <!-- Utilizing the class method here![cite: 1] -->
        <p class="text-3xl font-light mb-6 text-gray-800">
          {product.getFormattedPrice()}
        </p>
        
        <p class="text-gray-600 text-lg mb-8 leading-relaxed">
          {product.description}
        </p>
        
        <div class="mb-8">
          <!-- Utilizing the class method here too! -->
          <span class={`px-4 py-2 rounded-full text-sm font-bold tracking-wide ${product.inStock ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>
            {product.getAvailabilityMessage()}
          </span>
        </div>

        {/* Conditional rendering*/}
        
          <button class={
          `w-full md:w-auto px-12 py-4 
          ${product.inStock?"bg-black text-white":"bg-black/25 text-black/15"} 
          rounded font-bold
          ${product.inStock && "hover:bg-gray-800 transition-colors"} shadow-md`} disabled={!product.inStock}>
          Add to Cart
          </button>
        
      </div>
    </div>
  </div>
</Layout>